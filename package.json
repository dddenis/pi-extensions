{
  "name": "pi-extensions",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "pi": {
    "extensions": [
      "./src/attention-hooks/index.ts",
      "./src/custom-footer/index.ts",
      "./src/history-picker/index.ts",
      "./src/subagents/index.ts"
    ]
  },
  "scripts": {
    "fmt": "prettier --write .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.src.json && tsc -p tsconfig.test.json && tsc -p kit/tsconfig.json",
    "test": "bun --bun vitest run --reporter dot",
    "check": "bun typecheck && bun lint && bun run test",
    "pi:link-global": "bun run kit/main.ts pi link-global",
    "pi:unlink-global": "bun run kit/main.ts pi unlink-global",
    "postinstall": "umask 022 && effect-language-service patch"
  },
  "dependencies": {
    "@nozbe/microfuzz": "1.0.0",
    "effect": "^3.22.0",
    "typebox": "^1.3.6"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.7",
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@earendil-works/pi-tui": "^0.80.7",
    "@effect/cli": "^0.76.0",
    "@effect/language-service": "^0.87.0",
    "@effect/platform": "^0.97.0",
    "@effect/platform-bun": "^0.91.0",
    "@effect/vitest": "^0.30.0",
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.7"
  }
}
